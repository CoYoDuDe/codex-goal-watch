#!/usr/bin/env bash
set -euo pipefail
args=("$@")
if [[ ${1:-} == -ls ]]; then
  printf 'There are screens on:\n'
  while IFS= read -r name; do
    [[ -n $name ]] || continue
    printf '\t%s\t(Detached)\n' "$name"
  done < <(printf '%s' "${MOCK_SCREEN_SESSIONS:-101.alpha:}" | tr ':' '\n')
  printf '1 Socket in /run/screen/S-root.\n'
  exit 0
fi
joined=" ${args[*]} "
if [[ $joined == *' -Q windows '* ]]; then
  printf '%s\n' "${MOCK_WINDOWS:-0$ codex}"
  exit 0
fi
if [[ $joined == *' hardcopy '* ]]; then
  file=${args[${#args[@]} - 1]}
  [[ -z ${MOCK_HARDCOPY_LOG:-} ]] || printf '%s\n' "$file" >>"$MOCK_HARDCOPY_LOG"
  window=0
  for ((i = 0; i < ${#args[@]} - 1; i++)); do [[ ${args[$i]} == -p ]] && window=${args[$((i + 1))]}; done
  fixture=${MOCK_FIXTURE:-normal}
  source_file="$MOCK_FIXTURES/${fixture}.${window}"
  [[ -f $source_file ]] || source_file="$MOCK_FIXTURES/$fixture"
  cp "$source_file" "$file"
  exit 0
fi
if [[ $joined == *' stuff '* ]]; then
  printf '%q ' "${args[@]}" >>"$MOCK_SEND_LOG"
  printf '\n' >>"$MOCK_SEND_LOG"
  exit 0
fi
exit 0
